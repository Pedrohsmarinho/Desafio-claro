{
  "title": "Pedidos API - Visão Geral e Saúde",
  "uid": "pedidos-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total de pedidos",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "auto" },
      "targets": [
        { "expr": "sum(pedidos_by_status{application=\"pedidos-api\"})", "legendFormat": "total", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Em processamento",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "expr": "pedidos_by_status{application=\"pedidos-api\", status=\"EM_PROCESSAMENTO\"}",
          "legendFormat": "em processamento",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Peso total (kg)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "expr": "pedidos_peso_total_gramas{application=\"pedidos-api\"} / 1000",
          "legendFormat": "peso total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Itens totais",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "expr": "pedidos_itens{application=\"pedidos-api\"}",
          "legendFormat": "itens totais",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Saúde da API (/actuator/health via scrape do Prometheus)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "textMode": "value_and_name" },
      "targets": [{ "expr": "up{job=\"pedidos-api\"}", "legendFormat": "pedidos-api", "refId": "A" }]
    },
    {
      "id": 6,
      "title": "Pedidos criados (cumulativo, histórico)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "expr": "pedidos_total{application=\"pedidos-api\"}", "legendFormat": "criados (total histórico)", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "title": "Disponibilidade da API (última 1h)",
      "type": "timeseries",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "targets": [{ "expr": "up{job=\"pedidos-api\"}", "legendFormat": "up", "refId": "A" }]
    },
    {
      "id": 8,
      "title": "Requisições/s por endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"pedidos-api\"}[1m])) by (uri)",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Latência média",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_sum{application=\"pedidos-api\"}[1m])) / sum(rate(http_server_requests_seconds_count{application=\"pedidos-api\"}[1m]))",
          "legendFormat": "latência média",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Memória JVM (heap)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"pedidos-api\", area=\"heap\"}) by (id)",
          "legendFormat": "{{id}}",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{application=\"pedidos-api\", area=\"heap\"})",
          "legendFormat": "máximo",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "title": "Taxa de erros 4xx / 5xx",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"pedidos-api\", status=~\"4..\"}[1m]))",
          "legendFormat": "4xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"pedidos-api\", status=~\"5..\"}[1m]))",
          "legendFormat": "5xx",
          "refId": "B"
        }
      ]
    },
    {
      "id": 12,
      "title": "Logs do backend (tempo real, via Loki/Promtail)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"backend\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
