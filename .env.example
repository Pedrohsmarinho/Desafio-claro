# Copie este arquivo para ".env" (mesma pasta) e ajuste os valores antes de
# rodar "docker compose up". O ".env" real nunca deve ser commitado (ja esta
# no .gitignore) - cada pessoa/ambiente gera o proprio segredo.

# Segredo usado para assinar/validar o JWT (HMAC-SHA256, exige >= 256 bits).
# Gere um valor aleatorio novo, por exemplo: openssl rand -base64 48
JWT_SECRET=troque-por-um-valor-aleatorio-de-pelo-menos-32-bytes

# Usuario/senha da aplicacao no MariaDB - usados tanto para criar o usuario
# no container do banco quanto para a conexao do backend (DB_URL).
DB_USERNAME=pedidos_user
DB_PASSWORD=troque_esta_senha

# Senha do usuario root do MariaDB (so usada na criacao do container).
MARIADB_ROOT_PASSWORD=troque_esta_senha_root
